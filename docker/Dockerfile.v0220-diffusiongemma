FROM vllm/vllm-openai:v0.22.0-aarch64-ubuntu2404
LABEL org.opencontainers.image.source="https://github.com/r0b0tlab/diffusiongemma-26b-nvfp4-sm121-vllm"
LABEL org.opencontainers.image.description="vLLM v0.22.0 patched for DiffusionGemma NVFP4 on SM121"
ENV VLLM_USE_V2_MODEL_RUNNER=1
USER root
RUN apt-get update && apt-get install -y --no-install-recommends git patch && rm -rf /var/lib/apt/lists/*
COPY third_party/spark-vllm-docker/mods/diffusiongemma /opt/diffusiongemma-mods
RUN bash /opt/diffusiongemma-mods/run.sh
